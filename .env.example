NODE_ENV=production
PORT=8081
SQLITE_FILE=/var/www/dono/data/dono.sqlite
APP_TIME_ZONE=Asia/Tashkent
COOKIE_SECURE=true
DEFAULT_TENANT_ID=tenant_main
DONO_SECRET_ENCRYPTION_KEY=

# Global Telegram token fallback.
DONO_TELEGRAM_BOT_TOKEN=

# Tenant-scoped Telegram token override. tenant_main -> TENANT_MAIN.
DONO_TELEGRAM_BOT_TOKEN_TENANT_MAIN=
