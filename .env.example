NODE_ENV=production
PORT=8081
SQLITE_FILE=/var/www/dono/data/dono.sqlite
APP_TIME_ZONE=Asia/Tashkent
COOKIE_SECURE=true
TRUST_PROXY=true
DEFAULT_TENANT_ID=tenant_main
DONO_SEED_DEMO=false
DONO_SECRET_ENCRYPTION_KEY=

# Global Telegram token fallback.
DONO_TELEGRAM_BOT_TOKEN=

# Tenant-scoped Telegram token override. tenant_main -> TENANT_MAIN.
DONO_TELEGRAM_BOT_TOKEN_TENANT_MAIN=

# Optional age recipient used by scripts/backup.sh.
BACKUP_AGE_RECIPIENT=

# Attendance Strangler rollout. Keep all disabled until PostgreSQL shadow parity passes.
DATABASE_URL=
PG_POOL_MAX=10
PG_SSL=false
PG_QUERY_TIMEOUT_MS=5000
PG_READINESS_TIMEOUT_MS=2000
DONO_ATTENDANCE_MIRROR_ENABLED=false
# Comma-separated tenant IDs moved to PostgreSQL after canary approval.
DONO_ATTENDANCE_POSTGRES_TENANTS=
# Safety gate: set true only after the reverse relay and rollback drill pass.
DONO_ATTENDANCE_REVERSE_RELAY_READY=false
DONO_ATTENDANCE_REVERSE_RELAY_ENABLED=false
ATTENDANCE_RELAY_INTERVAL_MS=1000
