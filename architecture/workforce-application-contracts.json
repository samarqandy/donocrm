  "contractPolicy": {
    "publicBoundary": "Only contracts declared in this manifest are public. Domain entities, repositories, infrastructure models, provider internals, and HTTP request objects are private.",
    "compatibilityFacade": "The existing Workforce HTTP adapter invokes WorkforceCompatibilityApplicationV1 and maps its typed result/error to the frozen unversioned HTTP contract.",
    "coordinationPlacement": "WorkforceCompatibilityApplicationV1 is an outer Application coordinator assembled by Bootstrap; it owns workflow and compatibility composition but no provider data.",
    "canonicalInput": "The HTTP adapter resolves transport aliases, JavaScript coercion, ignored bodies, and legacy defaults before calling the canonical Application contract.",
    "authorization": "Application authorization is mandatory and is re-evaluated from verified WorkforceActorContextV1; HTTP prechecks are defense in depth, not the authorization owner.",
    "tenantIsolation": "Every public call carries an explicit verified tenantId. Caller-supplied DTO fields cannot override tenant or actor identity.",
    "errorModel": "Expected policy, validation, not-found, and conflict outcomes use the closed semantic error unions declared per contract. Unknown failures use the technical error union.",
    "httpStability": "No runtime route, request, response, status, ordering, or current persistence behavior is changed by this decision.",
    "noEntityLeak": "Public DTOs are immutable snapshots and never expose mutable Domain entities or provider-owned records."
  },
