  "operations": [
    {
      "id": "WF-HTTP-01",
      "method": "GET",
      "path": "/api/teachers",
      "useCase": "List Teachers",
      "authorization": "Authenticated tenant actor; Admin receives tenant directory, Teacher receives only own row",
      "request": "No body or query parameters",
      "successStatus": 200,
      "response": "{ teachers: TeacherAdmin[] } for Admin or zero/one { teachers: TeacherSelf[] } row for Teacher",
      "ordering": "active before inactive, then SQLite name ordering",
      "semanticErrors": []
    },
    {
      "id": "WF-HTTP-02",
      "method": "GET",
      "path": "/api/teachers/{teacherId}",
      "useCase": "Get Teacher Profile",
      "authorization": "Admin may read a tenant Teacher; Teacher may read only matching context.userId",
      "request": "Required decoded path teacherId; no body or query parameters",
      "successStatus": 200,
      "response": "TeacherProfile",
      "ordering": "groups active descending then name; working hours by Teacher name, numeric weekday, startTime; upcoming lessons by date then time, maximum 20",
      "semanticErrors": [
        {
          "status": 403,
          "error": "Only own teacher profile is available"
        },
        {
          "status": 404,
          "error": "Teacher not found"
        }
      ]
    },
