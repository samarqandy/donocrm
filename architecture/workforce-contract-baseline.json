  "requestDtos": {
    "TeacherWriteRequest": {
      "required": [
        "name"
      ],
      "acceptedFields": [
        "name",
        "phone",
        "email",
        "specialization",
        "employmentType",
        "employment_type",
        "hiredAt",
        "hired_at",
        "maxWeeklyHours",
        "max_weekly_hours",
        "note",
        "branchId",
        "branch_id",
        "accessEnabled",
        "access_enabled",
        "username",
        "password"
      ],
      "rules": [
        "name is trimmed and non-empty",
        "email is empty or matches the current email pattern",
        "employmentType is full_time, part_time, or contract",
        "hiredAt is empty or a real YYYY-MM-DD date",
        "maxWeeklyHours is numeric from 1 through 80 and is persisted as rounded minutes",
        "branchId is empty/defaulted or must exist in the active tenant",
        "create with an empty branchId defaults to the active tenant main Branch when one exists",
        "username is 3 through 80 characters from A-Z, a-z, 0-9, dot, underscore, at, plus, or hyphen when access is enabled",
        "password is at least 8 characters when first enabling access and whenever supplied",
        "accessEnabled and access_enabled use current JavaScript boolean coercion, so non-empty strings are truthy",
        "an inactive Teacher must be restored before portal access is enabled"
      ],
      "updateSemantics": [
        "PUT still requires name",
        "omitted phone, email, specialization, and note are cleared to empty strings",
        "omitted employmentType, hiredAt, maxWeeklyHours, branchId, access state, and username inherit current values",
        "empty hiredAt clears the date",
        "empty branchId does not clear an existing Branch reference"
      ]
    },
    "ResetTeacherPasswordRequest": {
      "requiredAlternatives": [
        "newPassword",
        "new_password"
      ],
      "rules": [
        "trimmed value is required",
        "minimum length is 8"
      ]
    },
    "CreateTeacherWorkingHourRequest": {
      "acceptedFields": [
        "teacherId",
        "teacher_id",
        "weekday",
        "startTime",
        "start_time",
        "endTime",
        "end_time",
        "branchId",
        "branch_id"
      ],
      "requiredAlternatives": [
        "teacherId or teacher_id",
        "startTime or start_time",
        "endTime or end_time"
      ],
      "rules": [
        "Teacher exists in the active tenant and is active",
        "weekday serializes as string 1 through 7",
        "startTime and endTime use strict HH:mm",
        "endTime is later than startTime",
        "same-Teacher same-weekday intervals do not overlap",
        "branchId is accepted but is not validated by the current use case",
        "empty branchId defaults to the active tenant main Branch when one exists"
      ]
    },
    "IgnoredJsonBody": {
      "required": [],
      "semantics": "Body is parsed and then ignored; malformed or oversized bodies still fail"
    }
  },
