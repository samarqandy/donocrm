  "temporaryExceptions": [],
  "blockingRisks": [
    {
      "id": "WF-ACCESS-RISK-01",
      "severity": "high",
      "tables": ["teachers", "users", "user_roles", "user_branch_access", "sessions"],
      "issue": "Legacy create/update/archive open transactions across Workforce- and Identity-owned tables.",
      "treatment": "No target foreign write; WF-PRE-11 must approve provider ordering, compensation, retry, and reconciliation."
    },
    {
      "id": "WF-ACCESS-RISK-02",
      "severity": "high",
      "tables": ["users", "groups", "students", "schedules", "lessons"],
      "issue": "The broad teachers() projection makes read and mutation responses depend on five foreign contexts.",
      "treatment": "WF-SEAM-06 outer composition plus exact WF-PRE-09/10 public reads; no broad Workforce query adapter."
    },
    {
      "id": "WF-ACCESS-RISK-03",
      "severity": "high",
      "tables": ["sessions"],
      "issue": "Current session deletes use user_id without a tenant predicate.",
      "treatment": "Identity contract receives verified tenant and Teacher reference; tenant-isolation and fan-out invalidation tests are mandatory in WF-PRE-13."
    },
    {
      "id": "WF-ACCESS-RISK-04",
      "severity": "high",
      "tables": ["branches", "teacher_working_hours"],
      "issue": "Explicit Working Hour branchId is not validated and branch_id has no FK.",
      "treatment": "WF-SEAM-RISK-01 remains blocking; exact compatibility/remediation is required in WF-PRE-09/13."
    },
    {
      "id": "WF-ACCESS-RISK-05",
      "severity": "high",
      "tables": ["audit_logs"],
      "issue": "Audit append is a foreign write after the business repository call.",
      "treatment": "WF-SEAM-07 provider append; WF-PRE-11/12 decide durable handoff and response/reconciliation behavior."
    }
  ],
