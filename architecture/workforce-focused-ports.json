  "compositionRules": {
    "TeacherAdminViewV1": {
      "workforce": ["TeacherAggregateSnapshotV1"],
      "identity-access": ["TeacherPortalAccessProjectionV1"],
      "academic-groups": ["TeacherGroupCountV1"],
      "scheduling": ["TeacherWorkloadProjectionV1"],
      "lesson-delivery": ["TeacherCompletedLessonCountV1"],
      "student-information": ["TeacherStudentCountV1"],
      "derivedByCoordinator": ["workloadPercent"],
      "rules": ["Missing keyed projection rows fail the complete composition; they are not silently zero-filled"]
    },
    "TeacherProfileGroupAdminViewV1": {
      "academic-groups": ["TeacherGroupBaseProjectionV1"],
      "scheduling": ["GroupScheduleProjectionV1"],
      "lesson-delivery": ["GroupLessonMetricsV1"],
      "student-information": ["GroupStudentCountV1"],
      "derivedByCoordinator": ["occupancyPercent", "attendanceRate"],
      "rules": [
        "occupancyPercent is derived from capacity and studentsCount using the frozen formula",
        "attendanceRate remains the frozen compatibility value 0 until an approved Attendance contract changes it",
        "Teacher self projection removes monthlyFee after composition"
      ]
    },
    "TeacherProfileLessonViewV1": {
      "lesson-delivery": ["TeacherProfileLessonViewV1"],
      "derivedByCoordinator": [],
      "rules": ["The provider returns an immutable compatibility projection, never a mutable Lesson entity"]
    },
    "TeacherWorkingHourViewV1": {
      "workforce": ["TeacherWorkingHourSnapshotV1", "TeacherBaseProjectionV1|TeacherReferenceV1"],
      "derivedByCoordinator": ["teacherName"],
      "rules": [
        "List/profile teacherName is joined in Application memory by tenant-scoped TeacherId",
        "Create teacherName uses the already-loaded TeacherReferenceV1 displayName",
        "Delete preserves the frozen empty teacherName quirk without an extra Teacher lookup",
        "No Working Hour adapter Teacher-table join is allowed"
      ]
    }
  },
  "broadPortProhibitions": [
    {
      "id": "WF-PORT-GUARD-01",
      "rule": "No port name or method may expose an unbounded generic repository/query/command, CRUD, execute, raw, SQL, table, database, transaction, or arbitrary-filter capability."
    },
    {
      "id": "WF-PORT-GUARD-02",
      "rule": "A provider port has exactly one providerContext and cannot claim tables or authority owned by another provider."
    },
    {
      "id": "WF-PORT-GUARD-03",
      "rule": "Only owned_repository and owned_query ports may declare allowedDirectTables, restricted to teachers or teacher_working_hours."
    },
    {
      "id": "WF-PORT-GUARD-04",
      "rule": "No command port returns provider credentials, hashes, sessions, roles, database rows, or mutable entities."
    },
    {
      "id": "WF-PORT-GUARD-05",
      "rule": "No UnitOfWork, event bus, outbox, migration router, retry executor, or cross-context transaction port is approved by WF-PRE-10."
    }
  ],
