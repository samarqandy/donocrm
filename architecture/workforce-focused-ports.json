  "policy": {
    "portOwnership": "A use-case consumer owns each outbound port interface. Provider public contracts remain provider-owned; anti-corruption adapters translate between the two.",
    "cohesion": "One port represents one aggregate persistence boundary, one owned read model, one provider capability, or one deterministic system capability.",
    "dependencyDirection": "Workforce Domain depends only on owned repository abstractions. The outer compatibility Application coordinator depends on focused outbound ports. Infrastructure adapters implement inward-facing ports.",
    "foreignAccess": "No Workforce adapter may directly read or write a foreign table. Provider adapters call the provider public Application boundary and return immutable snapshots or semantic decisions.",
    "batching": "Projection ports accept explicit unique teacherIds/groupIds batches. They do not expose generic filters, SQL, mutable provider entities, or lazy collections.",
    "batchCompleteness": "Every keyed count/access projection returns exactly one row for each requested ID, including explicit zero/not-granted values. Missing or duplicate keys are contract failures.",
    "failure": "Provider unknown/unavailable outcomes fail closed. No port returns partial success disguised as a complete snapshot.",
    "transactionBoundary": "No port spans authoritative writes in more than one bounded context. Cross-provider ordering, compensation, retry, reconciliation, and Unit of Work semantics remain WF-PRE-11.",
    "eventBoundary": "All ports are synchronous first-extraction contracts. No event publisher/subscriber port is approved before WF-PRE-12.",
    "runtimeStability": "This catalog creates no adapter or source module and changes no HTTP, persistence, schema, or runtime behavior."
  },
  "contexts": {
    "WorkforcePersistenceContextV1": {
      "fields": ["tenantId", "correlationId"],
      "fieldTypes": {
        "tenantId": "non-empty string",
        "correlationId": "non-empty string"
      },
      "rules": [
        "Constructed only from a verified Application context",
        "No actor, role, permission, session, credential, HTTP, or provider record is carried"
      ]
    },
    "WorkforcePortCallContextV1": {
      "fields": ["tenantId", "caller", "correlationId"],
      "fieldTypes": {
        "tenantId": "non-empty string",
        "caller": "workforce-compatibility-coordinator",
        "correlationId": "non-empty string"
      },
      "rules": [
        "The adapter authenticates the service caller to the provider",
        "No human session or credential is forwarded as service identity"
      ]
    }
  },
  "dataContracts": {
    "TeacherAggregateSnapshotV1": {
      "fields": [
        "id", "tenantId", "branchId", "name", "phone", "email", "specialization",
        "employmentType", "status", "hiredAt", "maxWeeklyMinutes", "note", "createdAt"
      ],
      "rules": [
        "Contains Workforce-owned facts only",
        "Portal access, workload, Group, Student, Lesson, and Audit facts are excluded"
      ]
    },
    "NewTeacherRecordV1": {
      "fields": [
        "id", "branchId", "name", "phone", "email", "specialization",
        "employmentType", "status", "hiredAt", "maxWeeklyMinutes", "note", "createdAt"
      ],
      "constants": {"status": "active"}
    },
    "TeacherProfileReplacementV1": {
      "fields": [
        "teacherId", "branchId", "name", "phone", "email", "specialization",
        "employmentType", "hiredAt", "maxWeeklyMinutes", "note"
      ]
    },
    "TeacherStatusChangeV1": {
      "fields": ["teacherId", "status"],
      "fieldTypes": {"status": "active|inactive"}
    },
    "TeacherBaseProjectionV1": {
      "base": "TeacherAggregateSnapshotV1",
      "orderingOnlyFields": [],
      "rules": ["No foreign projection field is present"]
    },
    "TeacherWorkingHourSnapshotV1": {
      "fields": [
        "id", "tenantId", "branchId", "teacherId", "weekday", "startTime", "endTime", "createdAt"
      ]
    },
    "NewTeacherWorkingHourRecordV1": {
      "fields": [
        "id", "branchId", "teacherId", "weekday", "startTime", "endTime", "createdAt"
      ]
    },
    "WorkingHourListFilterV1": {
      "fields": ["teacherId"],
      "fieldTypes": {"teacherId": "non-empty string|null"},
      "rules": ["null means all tenant Working Hours; a Teacher actor is normalized to its own ID before this port"]
    },
    "WorkingHourOverlapQueryV1": {
      "fields": ["teacherId", "weekday", "startTime", "endTime"],
      "rules": ["Overlap is existing.startTime < endTime and existing.endTime > startTime"]
    },
    "TeacherIdBatchV1": {
      "fields": ["teacherIds"],
      "fieldTypes": {"teacherIds": "readonly unique non-empty string[]"},
      "rules": ["Maximum batch size is the number of Teachers selected by the owning Application call"]
    },
    "GroupIdBatchV1": {
      "fields": ["groupIds"],
      "fieldTypes": {"groupIds": "readonly unique non-empty string[]"},
      "rules": ["IDs originate only from the approved Group base projection"]
    },
    "PortalProvisionIntentV1": {
      "fields": ["teacherId", "displayName", "username", "password", "branchId"],
      "fieldTypes": {
        "teacherId": "non-empty string",
        "displayName": "non-empty string",
        "username": "string",
        "password": "secret string",
        "branchId": "string|null"
      },
      "rules": ["password is redacted and may cross only this Identity command adapter"]
    },
    "PortalAccessChangeIntentV1": {
      "fields": ["teacherId", "displayName", "enabled", "username", "newPassword", "branchId"],
      "optionalFields": ["enabled", "username", "newPassword", "branchId"],
      "rules": ["newPassword is redacted and may cross only this Identity command adapter"]
    },
    "PortalDisableIntentV1": {
      "fields": ["teacherId"]
    },
    "CredentialResetIntentV1": {
      "fields": ["teacherId", "newPassword"],
      "rules": ["newPassword is redacted and may cross only the Identity credential-reset adapter"]
    },
    "TeacherPortalAccessProjectionV1": {
      "fields": ["teacherId", "hasAccess", "username", "accessStatus"],
      "fieldTypes": {
        "teacherId": "string",
        "hasAccess": "boolean",
        "username": "string",
        "accessStatus": "active|inactive|not_granted"
      }
    },
    "BranchResolutionRequestV1": {
      "fields": ["requestedBranchId", "useMainWhenOmitted"],
      "fieldTypes": {
        "requestedBranchId": "string|null",
        "useMainWhenOmitted": "boolean"
      }
    },
    "BranchResolutionV1": {
      "fields": ["branchId", "resolution"],
      "fieldTypes": {
        "branchId": "string|null",
        "resolution": "explicit|main|none"
      }
    },
    "ArchiveBlockerDecisionV1": {
      "fields": ["teacherId", "blocked"],
      "fieldTypes": {"teacherId": "string", "blocked": "boolean"},
      "rules": ["No Group or Lesson row/detail is returned"]
    },
    "TeacherGroupCountV1": {
      "fields": ["teacherId", "groupsCount"]
    },
    "TeacherGroupBaseProjectionV1": {
      "fields": [
        "id", "tenantId", "branchId", "name", "subject", "description", "level",
        "teacherId", "teacherName", "room", "monthlyFee", "capacity", "startDate",
        "endDate", "status", "color", "note", "archivedAt", "archiveReason",
        "createdAt", "updatedAt", "active"
      ],
      "rules": [
        "Contains Academic Groups-owned base facts only",
        "Teacher self monthlyFee omission is applied by the compatibility coordinator"
      ]
    },
    "TeacherWorkloadProjectionV1": {
      "fields": ["teacherId", "weeklyMinutes"]
    },
    "GroupScheduleProjectionV1": {
      "fields": ["groupId", "schedulesCount", "scheduleSummary"]
    },
    "TeacherCompletedLessonCountV1": {
      "fields": ["teacherId", "completedLessons"]
    },
    "GroupLessonMetricsV1": {
      "fields": [
        "groupId", "totalLessons", "plannedLessons", "completedLessons",
        "cancelledLessons", "nextLessonDate"
      ]
    },
    "TeacherStudentCountV1": {
      "fields": ["teacherId", "studentsCount"]
    },
    "GroupStudentCountV1": {
      "fields": ["groupId", "studentsCount"]
    },
    "WorkforceAuditIntentV1": {
      "fields": ["actorUserId", "action", "entityType", "entityId", "correlationId"],
      "fieldTypes": {
        "actorUserId": "non-empty string",
        "action": "created|updated|archived|restored|reset_password|deleted",
        "entityType": "teacher|teacher_working_hour",
        "entityId": "non-empty string",
        "correlationId": "non-empty string"
      },
      "rules": [
        "tenantId is supplied only by WorkforcePortCallContextV1",
        "Password, username, contact, request body, provider record, and mutable entity data are forbidden",
        "Audit owns record ID, timestamp, retention, and storage"
      ]
    },
    "GeneratedIdKindV1": {
      "values": ["teacher", "teacher_working_hour"]
    }
  },
  "errorContracts": {
    "OWNED_RECORD_CONFLICT": {
      "owner": "workforce",
      "mapping": "WORKFORCE_FAILURE",
      "rule": "Insert/update uniqueness or invariant conflict not already expressed by the Application contract"
    },
    "IDENTITY_USERNAME_CONFLICT": {
      "owner": "identity-access",
      "mapping": "USERNAME_CONFLICT"
    },
    "IDENTITY_PORTAL_NOT_CONFIGURED": {
      "owner": "identity-access",
      "mapping": "PORTAL_ACCESS_NOT_CONFIGURED"
    },
    "BRANCH_REFERENCE_INVALID": {
      "owner": "organization-branches",
      "mapping": "BRANCH_INVALID"
    },
    "PROVIDER_UNAVAILABLE": {
      "owner": "provider",
      "mapping": "WORKFORCE_UNAVAILABLE"
    },
    "PROVIDER_FAILURE": {
      "owner": "provider",
      "mapping": "WORKFORCE_FAILURE"
    },
    "AUDIT_APPEND_FAILED": {
      "owner": "audit-history",
      "mapping": "WORKFORCE_FAILURE"
    }
  },
